# Environment variables (never commit real env files — even .env.production,
# which Vite inlines into the public bundle). Templates with placeholders are OK.
.env
.env.*
frontend/.env
frontend/.env.*
!.env.example
!.env.sample
!frontend/.env.example
!frontend/.env.sample

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Database
*.db

# Node modules
node_modules/

# Vite build
frontend/dist/

# VS Code
.vscode/

# Claude context files
CLAUDE.md
tasks/
.claude/

# Runtime state
backend/quota.json
# machina cursor state (do not commit)
.machina/
